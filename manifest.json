{
  "manifest_version": 3,
  "name": "SensiDemo",
  "description": "Blur sensitive images and text per domain while recording product demos.",
  "version": "0.1.0",
  "permissions": ["activeTab", "scripting", "storage", "tabs"],
  "host_permissions": ["<all_urls>"],
  "icons": {
    "16": "assets/icons/sensidemo-16.png",
    "32": "assets/icons/sensidemo-32.png",
    "48": "assets/icons/sensidemo-48.png",
    "128": "assets/icons/sensidemo-128.png"
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "action": {
    "default_icon": {
      "16": "assets/icons/sensidemo-16.png",
      "32": "assets/icons/sensidemo-32.png",
      "48": "assets/icons/sensidemo-48.png",
      "128": "assets/icons/sensidemo-128.png"
    },
    "default_popup": "src/popup.html",
    "default_title": "SensiDemo"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.js"],
      "css": ["src/content.css"],
      "run_at": "document_idle"
    }
  ]
}
